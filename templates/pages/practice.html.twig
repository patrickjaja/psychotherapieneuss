{% extends 'base.html.twig' %}

{% block title %}Praxis - Psychotherapie Neuss{% endblock %}
{% block meta_description %}Psychotherapie-Praxis mit Altbaucharme in Neuss, Büchel 35. Anfahrt, Parkmöglichkeiten und Barrierefreiheit. Zentral gelegen nahe Hauptbahnhof.{% endblock %}
{% block canonical_url %}https://www.psychotherapieneuss.de/praxis{% endblock %}

{% block content %}
<section class="py-12 bg-gradient-to-b from-primary/10 to-white">
    <div class="container mx-auto px-4">
        <h1 class="text-4xl font-bold text-center mb-8">Die Praxis</h1>
    </div>
</section>

<section class="py-16">
    <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
            <div class="bg-white rounded-lg shadow-lg p-8 mb-12">
                <div class="prose prose-lg max-w-none text-neutral/90">
                    <p class="text-lg leading-relaxed mb-6">
                        Meine Praxis befindet sich in einem liebevoll sanierten Altbau am Büchel 35 in Neuss und ist sowohl mit öffentlichen Verkehrsmitteln als auch mit dem Auto gut erreichbar.
                    </p>
                    <p class="text-lg leading-relaxed mb-6">
                        Altes Fachwerk, warme Farbtöne und lichtdurchflutete Räume schaffen hier eine besondere Atmosphäre der Ruhe und Geborgenheit. Der Charme des Altbaus verbindet sich mit einer behaglichen Einrichtung zu einem Ort, an dem Sie sich vom ersten Moment an willkommen fühlen können.
                    </p>
                </div>
            </div>

            <div class="grid md:grid-cols-2 gap-8 mb-12 items-center">
                <div>
                    <img src="/images/IMG-20260227-WA0022.jpg" alt="Praxisräume im Altbau mit historischem Fachwerk" class="rounded-lg shadow-lg w-full">
                </div>
                <div class="bg-primary/5 rounded-lg p-6">
                    <h2 class="text-xl font-bold mb-4">Altbaucharme trifft Wohlfühlatmosphäre</h2>
                    <p class="text-neutral/90 leading-relaxed">
                        Die großzügigen Räumlichkeiten des Altbaus bieten einen ruhigen, geschützten Rahmen für die therapeutische Arbeit. Stilvoll eingerichtet und mit viel Liebe zum Detail gestaltet, laden die Praxisräume dazu ein, zur Ruhe zu kommen und sich auf das Wesentliche zu konzentrieren.
                    </p>
                </div>
            </div>

            <div class="bg-primary/5 rounded-lg p-8 mb-12">
                <h2 class="text-2xl font-bold mb-6">Was Sie erwartet</h2>
                <div class="grid md:grid-cols-2 gap-6">
                    <div class="flex items-start">
                        <svg class="w-6 h-6 text-primary mt-1 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                        </svg>
                        <div>
                            <h3 class="font-semibold mb-1">Zentrale Lage</h3>
                            <p class="text-neutral/90">Gute Erreichbarkeit in der Neusser Innenstadt</p>
                        </div>
                    </div>
                    <div class="flex items-start">
                        <svg class="w-6 h-6 text-primary mt-1 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                        </svg>
                        <div>
                            <h3 class="font-semibold mb-1">Altbaucharme</h3>
                            <p class="text-neutral/90">Historisches Fachwerk und lichtdurchflutete Räume mit besonderem Charakter</p>
                        </div>
                    </div>
                    <div class="flex items-start">
                        <svg class="w-6 h-6 text-primary mt-1 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                        </svg>
                        <div>
                            <h3 class="font-semibold mb-1">Geborgene Atmosphäre</h3>
                            <p class="text-neutral/90">Warme, einladende Räumlichkeiten für Ihr Wohlbefinden</p>
                        </div>
                    </div>
                    <div class="flex items-start">
                        <svg class="w-6 h-6 text-primary mt-1 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                        </svg>
                        <div>
                            <h3 class="font-semibold mb-1">Diskreter Zugang</h3>
                            <p class="text-neutral/90">Geschützter Rahmen für Ihre Therapie</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-yellow-50 border-l-4 border-yellow-400 p-6">
                <div class="flex">
                    <div class="flex-shrink-0">
                        <svg class="h-6 w-6 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                        </svg>
                    </div>
                    <div class="ml-3">
                        <p class="text-sm text-yellow-700">
                            <strong>Hinweis zur Barrierefreiheit:</strong> Da sich im Eingangsbereich Treppenstufen befinden, ist der Zugang zur Praxis leider nicht barrierefrei. Bitte kontaktieren Sie mich, wenn Sie besondere Unterstützung benötigen.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
